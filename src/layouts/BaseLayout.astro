---
import 'katex/dist/katex.min.css';
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { WorkbenchSidebar } from '@/components/WorkbenchSidebar';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  schema?: Array<Record<string, unknown>>;
  appShell?: boolean;
  showSidebar?: boolean;
}

const {
  title,
  description = 'Free online markdown viewer with live preview. Render GFM, LaTeX, and Mermaid instantly.',
  canonicalUrl,
  schema = [],
  appShell = true,
  showSidebar = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/logo-square.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <ClientRouter />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    <script defer data-domain="mdviewer.net" src="https://app.pageview.app/js/script.js"></script>
    {schema.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body class:list={[appShell && 'app-shell-body']}>
    {appShell ? (
      <div class="app-container">
        {showSidebar ? <WorkbenchSidebar client:load /> : null}
        <main class="main-content">
          <slot />
        </main>
      </div>
    ) : (
      <slot />
    )}
  </body>
</html>
