---
import 'katex/dist/katex.min.css';
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { WorkbenchSidebar } from '@/components/WorkbenchSidebar';
import type { Locale } from '@/lib/i18n';
import { localeToLangTag } from '@/lib/i18n';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  schema?: Array<Record<string, unknown>>;
  appShell?: boolean;
  showSidebar?: boolean;
  locale?: Locale;
  alternateLocales?: Array<{ locale: Locale | 'x-default'; href: string }>;
}

const {
  title,
  description = 'Free online markdown viewer with live preview. Render GFM, LaTeX, and Mermaid instantly.',
  canonicalUrl,
  schema = [],
  appShell = true,
  showSidebar = true,
  locale = 'en',
  alternateLocales = [],
} = Astro.props;
---

<!doctype html>
<html lang={localeToLangTag[locale]} data-locale={locale}>
  <head>
    <script is:inline>
      (function() {
        const root = document.documentElement;
        const locale = root.dataset.locale;

        function resolveTheme() {
          return localStorage.getItem('mdviewer.theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        }

        function applyTheme() {
          root.classList.toggle('dark', resolveTheme() === 'dark');
        }

        function applyLocale() {
          if (!locale) {
            return;
          }

          root.lang = locale === 'zh-cn' ? 'zh-CN' : 'en';
          root.dataset.locale = locale;
        }

        root.classList.add('is-loading');
        applyTheme();
        applyLocale();
        
        window.addEventListener('load', () => {
          setTimeout(() => {
            root.classList.remove('is-loading');
          }, 10);
        });

        document.addEventListener('astro:after-swap', () => {
          applyTheme();
          applyLocale();
        });
        document.addEventListener('astro:page-load', () => {
          applyTheme();
          applyLocale();
        });
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/logo-square.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <ClientRouter />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    {alternateLocales.map((entry) => (
      <link rel="alternate" hreflang={entry.locale === 'zh-cn' ? 'zh-CN' : entry.locale} href={entry.href} />
    ))}
    <script defer data-domain="mdviewer.net" src="https://app.pageview.app/js/script.js"></script>
    {schema.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body class:list={[appShell && 'app-shell-body']}>
    {appShell ? (
      <div class="app-container">
        {showSidebar ? <WorkbenchSidebar client:load locale={locale} /> : null}
        <main class="main-content">
          <slot />
        </main>
      </div>
    ) : (
      <slot />
    )}
  </body>
</html>
