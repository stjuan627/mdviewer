---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { WorkbenchBoot } from '@/components/WorkbenchBoot';
import { getLandingPageConfig, resolveCanonicalUrl } from '@/lib/landing-pages';

export const prerender = false;

const landing = getLandingPageConfig('home');

const canonicalUrl = resolveCanonicalUrl(landing.path, Astro.site);
---

<BaseLayout
  title={landing.title}
  description={landing.description}
  canonicalUrl={canonicalUrl}
  schema={landing.schema}
>
  <WorkbenchBoot
    client:load
    title={landing.heroTitle}
    description={landing.heroDescription}
    initialMarkdown={landing.initialMarkdown}
    variant={landing.workbenchVariant}
  />
</BaseLayout>
