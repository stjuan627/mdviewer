---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { WorkbenchBoot } from '@/components/WorkbenchBoot';

export const prerender = false;

const canonicalUrl = Astro.site?.toString() ?? 'https://mdviewer.net';
const title = 'MD Viewer - Online Markdown Editor with Live Preview';
const description =
  'Free online markdown editor with live preview, clean HTML output, PDF export, and shareable links. Write, format, preview, and export Markdown in one workspace.';
const heroTitle = 'Markdown Live Preview';
const heroDescription =
  'Preview Markdown live, copy clean HTML, export polished output, and share rendered pages easily.';
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'MD Viewer',
    url: canonicalUrl,
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'MD Viewer',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    url: canonicalUrl,
    description,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    featureList: [
      'Online Markdown editor',
      'Live Markdown preview',
      'PDF export',
      'Copy clean HTML output',
      'Share rendered Markdown pages',
    ],
  },
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} schema={schema}>
  <WorkbenchBoot client:load title={heroTitle} description={heroDescription} />
</BaseLayout>
