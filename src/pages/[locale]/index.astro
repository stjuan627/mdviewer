---
import LandingPageShell from '@/components/LandingPageShell.astro';
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, normalizeLocale } from '@/lib/i18n';

export const prerender = true;

export function getStaticPaths() {
  return SUPPORTED_LOCALES.filter((locale) => locale !== DEFAULT_LOCALE).map((locale) => ({
    params: { locale },
  }));
}
---

<LandingPageShell slug="home" locale={normalizeLocale(Astro.params.locale)} />
