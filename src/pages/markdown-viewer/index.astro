---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ViewerWorkbenchEntry } from '@/components/ViewerWorkbenchEntry';
import { getLandingPageConfig, resolveCanonicalUrl } from '@/lib/landing-pages';

export const prerender = true;

const landing = getLandingPageConfig('markdown-viewer');
const canonicalUrl = resolveCanonicalUrl(landing.path, Astro.site);
---

<BaseLayout
  title={landing.title}
  description={landing.description}
  canonicalUrl={canonicalUrl}
  schema={landing.schema}
>
  <main class="page">
    <div class="shell viewer-card">
      <section class="hero-card">
        <span class="hero-kicker">SEO entry: markdown viewer</span>
        <h1 class="hero-title">{landing.heroTitle}</h1>
        <p class="hero-copy">{landing.heroDescription}</p>
      </section>

      <section class="panel" style="margin-top: 20px;">
        <ViewerWorkbenchEntry client:load initialMarkdown={landing.initialMarkdown} />
        <p class="viewer-note">
          Long drafts stay in client-side session state for the handoff into the workbench. Share links continue to use
          a separate server-side persistence flow.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>
