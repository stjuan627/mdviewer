---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultMarkdown } from '@/lib/sample-markdown';
import { MAX_URL_PAYLOAD_LENGTH } from '@/lib/constants';

export const prerender = true;

const previewMarkdown = defaultMarkdown;
const previewPayload = encodeURIComponent(previewMarkdown);
const previewHref = `/workbench?view=article&source=markdown-viewer&payload=${previewPayload}`;
---

<BaseLayout title="Markdown Viewer — markdown.box" description="Preview Markdown, then jump into the full publishing workbench.">
  <main class="page">
    <div class="shell viewer-card">
      <section class="hero-card">
        <span class="hero-kicker">SEO entry: markdown viewer</span>
        <h1 class="hero-title">先看 Markdown，再把它送进完整发布工作台。</h1>
        <p class="hero-copy">
          这个页面满足“快速查看 Markdown”的单一意图；真正的发布增强效果在 Article View 里完成。
        </p>
      </section>

      <section class="panel" style="margin-top: 20px;">
        <form class="viewer-form" action="/workbench" method="GET">
          <input type="hidden" name="view" value="article" />
          <input type="hidden" name="source" value="markdown-viewer" />
          <div class="panel-header">
            <div>
              <h2 style="margin: 0;">Paste Markdown</h2>
              <p class="muted" style="margin-bottom: 0;">短内容会直接通过 URL 带入 Workbench；超长内容会自动回落到默认示例。</p>
            </div>
          </div>
          <textarea class="editor" aria-label="Markdown viewer input" name="payload">{previewMarkdown}</textarea>
          <div class="hero-actions">
            <button class="button-primary" type="submit">进入 Article workbench</button>
            <a class="button button-secondary" href={previewHref}>直接看默认示例</a>
          </div>
        </form>
        <p class="viewer-note">URL 安全载荷上限：{MAX_URL_PAYLOAD_LENGTH} 字符。</p>
      </section>
    </div>
  </main>
</BaseLayout>
