---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ViewerWorkbenchEntry } from '@/components/ViewerWorkbenchEntry';
import { defaultMarkdown } from '@/lib/sample-markdown';

export const prerender = true;

const previewMarkdown = defaultMarkdown;
---

<BaseLayout title="MD Viewer" description="Preview Markdown, then open the full workbench with the same draft.">
  <main class="page">
    <div class="shell viewer-card">
      <section class="hero-card">
        <span class="hero-kicker">SEO entry: markdown viewer</span>
        <h1 class="hero-title">先看 Markdown，再把它送进完整发布工作台。</h1>
        <p class="hero-copy">
          这个页面满足“快速查看 Markdown”的单一意图；需要复制 HTML 或生成分享页时，再进入完整工作台。
        </p>
      </section>

      <section class="panel" style="margin-top: 20px;">
        <ViewerWorkbenchEntry client:load initialMarkdown={previewMarkdown} />
        <p class="viewer-note">长文本会在当前会话内通过客户端状态带入 Workbench；分享链接仍由独立服务端机制处理。</p>
      </section>
    </div>
  </main>
</BaseLayout>
