---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Workbench } from '@/components/Workbench';
import { parseWorkbenchSearchParams } from '@/lib/schemas';

export const prerender = false;

const init = parseWorkbenchSearchParams(Astro.url.searchParams);
---

<BaseLayout title="Workbench — markdown.box" description="Switch one Markdown draft into article or release-ready output.">
  <Workbench
    client:load
    initialMarkdown={init.markdown}
    initialView={init.view}
    source={init.source}
    payloadDropped={init.payloadDropped}
  />
</BaseLayout>
