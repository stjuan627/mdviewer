---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslation } from '@/components/i18n/I18nProvider';
import { normalizeLocale } from '@/lib/i18n';

const locale = normalizeLocale(Astro.url.searchParams.get('locale'));
---

<BaseLayout
  title={getTranslation(locale, 'print.title')}
  description={getTranslation(locale, 'print.description')}
  appShell={false}
  showSidebar={false}
  locale={locale}
>
  <section class="print-preview-shell">
    <div class="print-preview-status" data-print-preview-status>{getTranslation(locale, 'print.preparing')}</div>
    <article class="print-preview-frame prose" data-print-preview-frame hidden></article>
  </section>

  <script
    is:inline
    define:vars={{
      locale,
      unavailableMessage: getTranslation(locale, 'print.unavailable'),
      openFailedMessage: getTranslation(locale, 'print.openFailed'),
      restoreFailedMessage: getTranslation(locale, 'print.restoreFailed'),
    }}
  >
    const storageKey = 'mdviewer-browser-print-payload';
    const messages = {
      unavailable: unavailableMessage,
      openFailed: openFailedMessage,
      restoreFailed: restoreFailedMessage,
    };
    const statusNode = document.querySelector('[data-print-preview-status]');
    const frameNode = document.querySelector('[data-print-preview-frame]');

    const setStatus = (message) => {
      if (statusNode) {
        statusNode.textContent = message;
      }
    };

    const rawPayload = window.localStorage.getItem(storageKey);

    if (!rawPayload || !frameNode) {
      setStatus(messages.unavailable);
    } else {
      window.localStorage.removeItem(storageKey);

      try {
        const payload = JSON.parse(rawPayload);
        document.title = payload.title || '';
        frameNode.setAttribute('data-theme', payload.themeId || 'paper');
        frameNode.innerHTML = payload.html || '';
        frameNode.hidden = false;
        setStatus('');

        const openPrintDialog = async () => {
          if (document.fonts && document.fonts.ready) {
            await document.fonts.ready;
          }

          await new Promise((resolve) => {
            requestAnimationFrame(() => requestAnimationFrame(resolve));
          });

          window.print();
        };

        window.addEventListener('afterprint', () => {
          window.close();
        });

        void openPrintDialog().catch((error) => {
          console.error(error);
          setStatus(messages.openFailed);
        });
      } catch (error) {
        console.error(error);
        setStatus(messages.restoreFailed);
      }
    }
  </script>
</BaseLayout>
